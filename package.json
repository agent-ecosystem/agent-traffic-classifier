{
  "name": "agent-traffic-classifier",
  "version": "0.1.1",
  "description": "Classify web traffic into humans, bots, AI agents, and programmatic clients from access logs and HTTP header signals",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint . && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "prepare": "husky",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "ai-agent",
    "bot-detection",
    "traffic-classification",
    "web-analytics",
    "access-log",
    "crawler",
    "user-agent",
    "agent traffic"
  ],
  "author": "Dachary Carey",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-ecosystem/agent-traffic-classifier.git"
  },
  "bugs": {
    "url": "https://github.com/agent-ecosystem/agent-traffic-classifier/issues"
  },
  "homepage": "https://github.com/agent-ecosystem/agent-traffic-classifier",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "isbot": "^5.1.37"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.3"
  }
}
